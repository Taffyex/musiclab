# ─── MusicLab Environment Configuration ───

# Secret key for signing session tokens (change this!)
APP_SECRET_KEY=change-me-to-a-random-string

# ─── Last.fm API ───
LASTFM_API_KEY=
LASTFM_USERNAME=

# ─── Lidarr Integration ───
LIDARR_URL=
LIDARR_API_KEY=

# ─── LLM Provider ───
# Options: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# ─── Discogs ───
DISCOGS_TOKEN=

# ─── Auth Defaults ───
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=
